# Copy this file to .env and fill in your own values.
# .env is already excluded via .gitignore - never commit real credentials.
#
# Leave both COSMOS_ENDPOINT and PG_HOST blank/unset to use the built-in
# SQLite database instead.
#
# Precedence if more than one is set: Cosmos DB > Postgres > SQLite.

# --- Option A: Azure Cosmos DB ---
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-key>
# Optional overrides (defaults shown)
# COSMOS_DB=ICC1db
# COSMOS_CONTAINER=tasks

# --- Option B: Azure Database for PostgreSQL ---
PG_HOST=<your-server-name>.postgres.database.azure.com
PG_USER=<your-username>
PG_PASSWORD=<your-password>
# Optional overrides (defaults shown)
# PG_PORT=5432
# PG_DB=icc1db
# PG_SSLMODE=require
